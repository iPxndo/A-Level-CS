using System;

public class Program
{
	public static void Main()
	{
		int number = 10;
		bool divisible = false;
		do
		{
			
			number = number + 1;
			
			for (int i = 2; i < 11; i++)
			{
				
				if (number % i == 0){
				}
				
				else {
					break;
				}

				if (i == 10) {
					divisible = true;
				}
			
			}
		
		} while (divisible == false);
		
		Console.WriteLine($"Number = {number}");
	
	}
}
