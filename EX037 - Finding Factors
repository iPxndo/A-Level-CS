using System;

public class Program
{
	public static void Main()
	{
		int factors = 0;
		int num = 0;
		
		try {
		Console.Write("Enter Whole Number: ");
		num = Convert.ToInt32(Console.ReadLine());
		}
		catch {
			Console.WriteLine("Not a Valid Number!");
		}
		
		Console.WriteLine();
		
		for(int x = 1; x<=num; x++) {
			if(num%x == 0) {
				Console.WriteLine(x);
				factors = factors+1;
			}
		}
		
		if (factors == 2) {
			Console.WriteLine("PRIME NUMBER!!!");
		}
	
	}
}
